;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:x-small&quot;&gt;&lt;strong&gt;Aktenzeichen:&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:x-small&quot;&gt;&lt;strong&gt;#ANTRAG_AKTENZEICHEN#&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&lt;/tr&gt;&#13;&#10;&#9;&#9;&lt;tr&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:x-small&quot;&gt;&lt;strong&gt;Förderzeitraum:&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:x-small&quot;&gt;&lt;strong&gt;#ANTRAG_LAUFZEIT_BEGINN# - #ANTRAG_LAUFZEIT_ENDE#&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&lt;/tr&gt;&#13;&#10;&#9;&#9;&lt;tr&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:x-small&quot;&gt;&lt;strong&gt;Anzahl Teilnehmende:&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:x-small&quot;&gt;&lt;strong&gt;#ANZAHL_TLN#&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&lt;/tr&gt;&#13;&#10;&#9;&#9;&lt;tr&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:x-small&quot;&gt;&lt;strong&gt;Eingang&amp;nbsp;&lt;span style=&quot;font-size:x-small&quot;&gt;&lt;strong&gt;rechtsverbindlicher&lt;/strong&gt;&lt;/span&gt; Regelverwendungsnachweis am:&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:x-small&quot;&gt;&lt;strong&gt;#BO_STATUS_DATE_ANY(EB20)#&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&lt;/tr&gt;&#13;&#10;&#9;&#9;&lt;tr&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:x-small&quot;&gt;&lt;strong&gt;Eingang prüffähiger Regelverwendungsnachweis am:&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:x-small&quot;&gt;&lt;strong&gt;#BO_STATUS_DATE_ANY_LAST(EB20)#&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&lt;/tr&gt;&#13;&#10;&#9;&lt;/tbody&gt
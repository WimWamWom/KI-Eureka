      <FormComponent created="15.09.2025 09:43:17" descriptor="FIXEDTEXT_005" importKey="FIXEDTEXT_005" info="" label="" mandatory="false" modified="15.09.2025 09:43:17" param1="" param10="" param11="" param12="" param13="" param14="" param15="" param16="" param17="" param18="" param19="" param2="" param20="" param3="" param4="" param5="" param6="" param7="" param8="" param9="" readonly="false" richCLOB="&lt;p&gt;&lt;span style=&quot;font-size:small&quot;&gt;Der/Die Zuwendungsempfänger/in erklär/t/en mit der Weiterleitung des Teilnehmerberichtes, dass...&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;ul&gt;&#13;&#10;&#9;&lt;li&gt;&lt;span style=&quot;font-size:small&quot;&gt;die Teilnehmenden der Maßnahme nachweislich über die Mitfinanzierung informiert wurden,&lt;/span&gt;&lt;/li&gt;&#13;&#10;&#9;&lt;li&gt;&lt;span style=&quot;font-size:small&quot;&gt;die Maßnahme den Vorschriften und Zielen des Landes Berlin einschließlich der Bestimmungen über den öffentlichen Wettbewerb, die Vergabe öffentlicher Aufträge, den Umweltschutz und dem Gleichbehandlungsgrundsatz von Männern und Frauen entsprochen hat,&lt;/span&gt;&lt;/li&gt;&#13;&#10;&#9;&lt;li&gt;&lt;span style=&quot;font-size:small&quot;&gt;die Teilnehmenden der Maßnahme ihren Wohnsitz ausschließlich im beantragten und bewilligten Fördergebiet haben,&lt;/span&gt;&lt;/li&gt;&#13;&#10;&#9;&lt;li&gt;&lt;span style=&quot;font-size:small&quot;&gt;die Auflagen und Bedingungen beachtet wurden,&lt;/span&gt;&lt;/li&gt;&#13;&#10;&#9;&lt;li&gt;&lt;span style=&quot;font-size:small&quot;&gt;die Daten im TRS zu den Teilnehmenden dem aktuellen Stand entsprechen.&lt;/span&gt;&lt;/li&gt;&#13;&#10;&lt;/ul&gt;&#13;&#10;" showErrors="true" sortIndex="0" sourceType="" submitOnChange="false" type="FIXEDRICHTEXT" usageType="" useLabelLeft="false" uuid="5b6a8308-7535-484e-b949-213dd2fb95fa"/>
    </FormDefinition>
  </Webpage>

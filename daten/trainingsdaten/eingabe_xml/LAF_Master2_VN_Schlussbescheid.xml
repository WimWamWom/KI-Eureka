sp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;font-size:small&quot;&gt; Berlin, den &lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;font-size:small&quot;&gt;#BO_STATUS_DDMMYYYY(EB45)#&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;table border=&quot;0&quot; cellpadding=&quot;3&quot; style=&quot;width:100%&quot;&gt;&#13;&#10;&#9;&lt;tbody&gt;&#13;&#10;&#9;&#9;&lt;tr&gt;&#13;&#10;&#9;&#9;&#9;&lt;td style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size:medium&quot;&gt;&lt;strong&gt;Schlussbescheid&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&lt;/tr&gt;&#13;&#10;&#9;&lt;/tbody&gt;&#13;&#10;&lt;/table&gt;&#13;&#10;&#13;&#10;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;table border=&quot;0&quot; cellpadding=&quot;3&quot; style=&quot;width:100%&quot;&gt;&#13;&#10;&#9;&lt;tbody&gt;&#13;&#10;&#9;&#9;&lt;tr&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:small&quot;&gt;&lt;strong&gt;Förderinstrument:&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;strong&gt;&lt;span style=&quot;font-size:small&quot;&gt;#ANTRAG_PROMOLEVEL#&lt;/span&gt;&lt;/strong&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&lt;/tr&gt;&#13;&#10;&#9;&#9;&lt;tr&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:small&quot;&gt;&lt;strong&gt;Maßnahmebezeichnung:&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:small&quot;&gt;#ANTRAG_NAME#&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&lt;/tr&gt;&#13;&#10;&#9;&#9;&lt;tr&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:small&quot;&gt;&lt;strong&gt;Projektnummer:&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:small&quot;&gt;#ANTRAG_PROJEKTNUMMER#&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&lt;/tr&gt;&#13;&#10;&#9;&#9;&lt;tr&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:small&quot;&gt;&lt;strong&gt;Aktenzeichen BwS:&lt;/strong&gt;&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&#9;&lt;td&gt;&lt;span style=&quot;font-size:small&quot;&gt;#ANTRAG_AKTENZEICHEN#&lt;/span&gt;&lt;/td&gt;&#13;&#10;&#9;&#9;&lt;/tr&gt;&#13;&#10;&#9;&lt;/tbody&gt;&#13;&#10;&lt;/table&gt;&#13;&#10;&#13;&#10;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p&gt;&lt;span style=&quot;font-size:small&quot;&gt;Sehr geehrte Damen und Herren,&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p&gt;&lt;span style=&quot;font-size:small&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p&gt;&lt;span style=&quot;font-size:small&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size:small&quot;&gt;der von Ihnen am #BO_STATUS_DDMMYYYY(EB20)# eingereichte Verwendungsnachweis wurde von uns abschließend geprüft.&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p&gt;&lt;span style=&quot;font-size:small&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p&gt;&lt;span style=&quot;font-size:small&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size:small&quot;&gt;Damit bestätigen wir Ihnen die zweckentsprechende Verwendung von Zuwendungsmitteln in Höhe von #FINANCE_4_3_1_3(IST_IST)#.&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p&gt;&lt;span style=&quot;font-size:small&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size:small&quot;&gt;Darüber hinaus konnte anhand des von Ihnen eingereichten Sachberichtes festgestellt werden, dass der Projektzweck erreicht wurde.&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p&gt;&lt;span style=&quot;font-size:small&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size:small&quot;&gt;Vorsorglich weisen wir darauf hin, dass dieser Schlussbescheid das unabhängige Prüfungsrecht der Prüfeinrichtungen des Landes Berlin sowie der Prüfeinrichtungen der Europäischen Kommission nicht berührt.&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p&gt;&lt;span style=&quot;font-size:small&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size:small&quot;&gt;Gemäß den Bestimmungen sind alle Projektunterlagen sowie Originalbelege (Einnahme-/ Ausgabebelege) über die Einzelzahlungen zu Prüfzwecken bis zum Ende des Jahres 2023 vollständig und gesondert aufzubewahren.&lt;/span&gt;&lt;/p&gt;&#13;&#10;&#13;&#10;&lt;p&gt;&lt;span style=&quot;font-size:small&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&#13;&#10;" showErrors="true" sortIndex="0" sourceType="SELF" submitOnChange="false" type="FIXEDRICHTEXT" usageType="" useLabelLeft="false" uuid="1e0a8965-570d-4cba-9a41-f6cc5312655c"/>
      <FormComponent created="15.09.2025 09:43:11" descriptor="FIXEDTEXT_098" importKey="FIXEDTEXT_098" info="" label="" mandatory="false" modified="15.09.2025 09:43:11" param1="" param10="" param11="" param12="" param13="" param14="" param15="" param16="" param17="" param18="" param19="" param2="" param20="" param3="" param4="" param5="" param6="" param7="" param8="" param9="" readonly="false" richCLOB="&lt;p&gt;&lt;span style=&quot;font-size: small;&quot;&gt;&lt;strong&gt;Rechtsbehelfsbelehrung&lt;/strong&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: small;&quot;&gt;Gegen diesen Bescheid ist der Widerspruch zulässig. Der Widerspruch ist schriftlich oder zur Niederschrift innerhalb einer Frist von einem Monat nach Zugang dieses Bescheides einzulegen.&lt;/span&gt;&lt;/p&gt;&#13;&#10;&lt;p&gt;&lt;span style=&quot;font-size: small;&quot;&gt;Es wird darauf hingewiesen, dass die Frist nur dann eingehalten ist, wenn der Widerspruch innerhalb dieser Frist &lt;/span&gt;&lt;span style=&quot;font-size: small;&quot;&gt;bei #KONTAKT_PERSON_ZGS(Name)#, #KONTAKT_PERSON_ZGS(Straße)# #KONTAKT_PERSON_ZGS(Hausnummer)#, #KONTAKT_PERSON_ZGS(Postleitzahl)# #KONTAKT_PERSON_ZGS(Ort)#&lt;/span&gt;&lt;span style=&quot;font-size: small;&quot;&gt; eingegangen ist. Kann dem Widerspruch nicht abgeholfen werden, entscheidet die zuständige Senatsverwaltung über den Widerspruch.&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: small;&quot;&gt;Mit freundlichen Grüßen&lt;br&gt;#KONTAKT_PERSON_ZGS(Name)#&lt;/span&gt;&lt;/p&gt;&#13;&#10;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&#13;&#10;&lt;p&gt;&lt;span style=&quot;font-size: small;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;&#13;&#10;&lt;p&gt;&lt;span style=&quot;font-size: small;&quot;&gt;#KONTAKT_PERSON_ZGS(Titel)# #KONTAKT_PERSON_ZGS(Vorname)# #KONTAKT_PERSON_ZGS(Nachname)#&lt;/span&gt;&lt;/p&gt;" showErrors="true" sortIndex="1" sourceType="" submitOnChange="false" type="FIXEDRICHTEXT" usageType="" useLabelLeft="false" uuid="f95a55b5-41eb-4e9e-a151-bcd08b0c5daa"/>
